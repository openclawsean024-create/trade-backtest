{
  "version": 2,
  "builds": [
    {
      "src": "api/fundamental.js",
      "use": "@vercel/node"
    },
    {
      "src": "signal-monitor.js",
      "use": "@vercel/static"
    },
    {
      "src": "SPEC.md",
      "use": "@vercel/static"
    },
    {
      "src": "config.json.example",
      "use": "@vercel/static"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/fundamental",
      "dest": "/api/fundamental.js"
    },
    {
      "src": "/signal-monitor.js",
      "dest": "/signal-monitor.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
